# Property Data API Keys
# Copy this file to .env and add your actual API keys

# Zillow Bridge Interactive API
# Get your key at: https://bridgedataoutput.com/
ZILLOW_API_KEY=

# ATOM Data API
# Get your key at: https://www.atomdata.com/
ATOM_DATA_API_KEY=

# BatchData API  
# Get your key at: https://www.batchdata.com/
BATCH_DATA_API_KEY=

# Optional: Add more API keys as needed
# HOMESAGE_API_KEY=
