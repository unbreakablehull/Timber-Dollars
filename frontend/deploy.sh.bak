#!/bin/bash

# Deployment script for Unbreakable Frontend to AWS S3 + CloudFront

# Configuration
BUCKET_NAME="unbreakable-hull-frontend"
REGION="us-east-1"
DISTRIBUTION_ID=""  # Will be filled after CloudFront is created

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${GREEN}🚀 Starting deployment of Unbreakable Frontend${NC}"

# Load environment variables
if [ -f .env ]; then
    export $(cat .env | xargs)
fi

# Set AWS credentials
export AWS_ACCESS_KEY_ID=$AWS_ACCESS
export AWS_SECRET_ACCESS_KEY=$AWS_SECRET
export AWS_DEFAULT_REGION=$REGION

# Step 1: Build the frontend
echo -e "${YELLOW}📦 Building frontend for production...${NC}"
npm run build

if [ $? -ne 0 ]; then
    echo -e "${RED}❌ Build failed!${NC}"
    exit 1
fi

echo -e "${GREEN}✅ Build completed successfully${NC}"

# Step 2: Check if S3 bucket exists, create if not
echo -e "${YELLOW}🪣 Checking S3 bucket...${NC}"
if aws s3api head-bucket --bucket "$BUCKET_NAME" 2>/dev/null; then
    echo -e "${GREEN}✅ Bucket $BUCKET_NAME exists${NC}"
else
    echo -e "${YELLOW}Creating bucket $BUCKET_NAME...${NC}"
    aws s3api create-bucket --bucket $BUCKET_NAME --region $REGION
    
    # Enable static website hosting
    aws s3 website s3://$BUCKET_NAME/ --index-document index.html --error-document index.html
    
    # Set bucket policy for public read
    cat > /tmp/bucket-policy.json <<EOF
{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "PublicReadGetObject",
            "Effect": "Allow",
            "Principal": "*",
            "Action": "s3:GetObject",
            "Resource": "arn:aws:s3:::$BUCKET_NAME/*"
        }
    ]
}
EOF
    
    aws s3api put-bucket-policy --bucket $BUCKET_NAME --policy file:///tmp/bucket-policy.json
    rm /tmp/bucket-policy.json
    
    echo -e "${GREEN}✅ Bucket created and configured${NC}"
fi

# Step 3: Upload files to S3
echo -e "${YELLOW}📤 Uploading files to S3...${NC}"
aws s3 sync dist/ s3://$BUCKET_NAME/ --delete \
    --cache-control "public, max-age=31536000" \
    --exclude "index.html" \
    --exclude "*.json"

# Upload index.html with no-cache
aws s3 cp dist/index.html s3://$BUCKET_NAME/index.html \
    --cache-control "no-cache, no-store, must-revalidate"

# Upload JSON files
aws s3 sync dist/ s3://$BUCKET_NAME/ \
    --exclude "*" \
    --include "*.json" \
    --cache-control "no-cache"

echo -e "${GREEN}✅ Files uploaded successfully${NC}"

# Step 4: CloudFront invalidation (if Distribution ID is set)
if [ ! -z "$DISTRIBUTION_ID" ]; then
    echo -e "${YELLOW}🔄 Creating CloudFront invalidation...${NC}"
    aws cloudfront create-invalidation --distribution-id $DISTRIBUTION_ID --paths "/*"
    echo -e "${GREEN}✅ CloudFront invalidation created${NC}"
fi

# Display the website URL
echo -e "${GREEN}🎉 Deployment complete!${NC}"
echo -e "${GREEN}Website URL: http://$BUCKET_NAME.s3-website-$REGION.amazonaws.com${NC}"

if [ ! -z "$DISTRIBUTION_ID" ]; then
    CLOUDFRONT_DOMAIN=$(aws cloudfront get-distribution --id $DISTRIBUTION_ID --query 'Distribution.DomainName' --output text)
    echo -e "${GREEN}CloudFront URL: https://$CLOUDFRONT_DOMAIN${NC}"
fi